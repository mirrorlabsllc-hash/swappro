# SwapPro Environment Variables
# Copy this file to .env and fill in your values

# ChangeNOW API Key (get from https://changenow.io/)
CHANGENOW_API_KEY=your_changenow_api_key_here

# Server port (default: 3000)
PORT=3000

# Swap margin percentage applied to monetize swaps (e.g., 0.5 = 0.5%)
MARGIN_PERCENT=0.5

# Premium mode margin (applied when user opts in, lower than default)
PREMIUM_MARGIN_PERCENT=0.2

# Node environment
NODE_ENV=production
